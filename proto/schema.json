{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://healthbridge.local/proto/schema.json",
  "title": "HealthBridge wire protocol",
  "description": "Job and result plaintext shapes that flow between the CLI and the iOS app. In M1 these travel through the relay as base64; in M2+ they are encrypted before reaching the relay.",

  "$defs": {
    "ulid": {
      "type": "string",
      "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
      "description": "Crockford-base32 ULID."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 / ISO8601 with timezone, always UTC."
    },
    "sampleType": {
      "type": "string",
      "description": "Stable enum identifying a HealthKit sample type. The iOS app maps these to HKQuantityTypeIdentifier strings.",
      "enum": [
        "step_count",
        "active_energy_burned",
        "basal_energy_burned",
        "distance_walking_running",
        "distance_cycling",
        "distance_swimming",
        "distance_wheelchair",
        "distance_downhill_snow_sports",
        "distance_cross_country_skiing",
        "distance_paddle_sports",
        "distance_rowing",
        "distance_skating_sports",
        "push_count",
        "swimming_stroke_count",
        "flights_climbed",
        "apple_exercise_time",
        "apple_move_time",
        "apple_stand_time",
        "vo2_max",
        "running_power",
        "running_speed",
        "running_stride_length",
        "running_vertical_oscillation",
        "running_ground_contact_time",
        "cycling_power",
        "cycling_speed",
        "cycling_cadence",
        "cycling_functional_threshold_power",
        "cross_country_skiing_speed",
        "paddle_sports_speed",
        "rowing_speed",
        "physical_effort",
        "workout_effort_score",
        "estimated_workout_effort_score",
        "height",
        "body_mass",
        "body_mass_index",
        "lean_body_mass",
        "body_fat_percentage",
        "waist_circumference",
        "apple_sleeping_wrist_temperature",
        "heart_rate",
        "heart_rate_resting",
        "walking_heart_rate_average",
        "heart_rate_variability_sdnn",
        "heart_rate_recovery_one_minute",
        "atrial_fibrillation_burden",
        "oxygen_saturation",
        "body_temperature",
        "blood_pressure_systolic",
        "blood_pressure_diastolic",
        "respiratory_rate",
        "blood_glucose",
        "electrodermal_activity",
        "forced_expiratory_volume_1",
        "forced_vital_capacity",
        "inhaler_usage",
        "insulin_delivery",
        "number_of_times_fallen",
        "peak_expiratory_flow_rate",
        "peripheral_perfusion_index",
        "dietary_energy_consumed",
        "dietary_water",
        "dietary_protein",
        "dietary_carbohydrates",
        "dietary_fiber",
        "dietary_sugar",
        "dietary_fat_total",
        "dietary_fat_saturated",
        "dietary_fat_monounsaturated",
        "dietary_fat_polyunsaturated",
        "dietary_cholesterol",
        "dietary_sodium",
        "dietary_potassium",
        "dietary_calcium",
        "dietary_iron",
        "dietary_magnesium",
        "dietary_phosphorus",
        "dietary_zinc",
        "dietary_copper",
        "dietary_manganese",
        "dietary_chromium",
        "dietary_iodine",
        "dietary_molybdenum",
        "dietary_selenium",
        "dietary_chloride",
        "dietary_caffeine",
        "dietary_vitamin_a",
        "dietary_vitamin_b6",
        "dietary_vitamin_b12",
        "dietary_vitamin_c",
        "dietary_vitamin_d",
        "dietary_vitamin_e",
        "dietary_vitamin_k",
        "dietary_thiamin",
        "dietary_riboflavin",
        "dietary_niacin",
        "dietary_folate",
        "dietary_pantothenic_acid",
        "dietary_biotin",
        "environmental_audio_exposure",
        "environmental_sound_reduction",
        "headphone_audio_exposure",
        "apple_walking_steadiness",
        "walking_speed",
        "walking_step_length",
        "walking_asymmetry_percentage",
        "walking_double_support_percentage",
        "stair_ascent_speed",
        "stair_descent_speed",
        "six_minute_walk_test_distance",
        "basal_body_temperature",
        "uv_exposure",
        "time_in_daylight",
        "underwater_depth",
        "water_temperature",
        "blood_alcohol_content",
        "number_of_alcoholic_beverages",
        "apple_sleeping_breathing_disturbances",
        "sleep_analysis",
        "workout"
      ]
    },
    "unit": {
      "type": "string",
      "description": "HealthKit-compatible unit string (e.g. 'count', 'kcal', 'kg', 'mg/dL', 'count/min').",
      "examples": ["count", "kcal", "kg", "mg/dL", "count/min", "mL"]
    },
    "sample": {
      "type": "object",
      "required": ["type", "value", "unit", "start", "end"],
      "properties": {
        "uuid": { "type": "string", "description": "Server-assigned by HealthKit on writes; required on reads." },
        "type": { "$ref": "#/$defs/sampleType" },
        "value": { "type": "number" },
        "unit": { "$ref": "#/$defs/unit" },
        "start": { "$ref": "#/$defs/timestamp" },
        "end": { "$ref": "#/$defs/timestamp" },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "source": {
          "type": "object",
          "description": "Filled in by the iOS app on reads; ignored on writes.",
          "properties": {
            "name": { "type": "string" },
            "bundle_id": { "type": "string" }
          }
        }
      }
    },

    "readPayload": {
      "type": "object",
      "required": ["type", "from", "to"],
      "properties": {
        "type": { "$ref": "#/$defs/sampleType" },
        "from": { "$ref": "#/$defs/timestamp" },
        "to":   { "$ref": "#/$defs/timestamp" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 10000 }
      }
    },
    "readResult": {
      "type": "object",
      "required": ["type", "samples"],
      "properties": {
        "type": { "$ref": "#/$defs/sampleType" },
        "samples": { "type": "array", "items": { "$ref": "#/$defs/sample" } }
      }
    },

    "writePayload": {
      "type": "object",
      "required": ["sample"],
      "properties": {
        "sample": { "$ref": "#/$defs/sample" }
      }
    },
    "writeResult": {
      "type": "object",
      "required": ["uuid"],
      "properties": {
        "uuid": { "type": "string", "description": "HealthKit-assigned UUID of the saved sample." }
      }
    },

    "syncPayload": {
      "type": "object",
      "required": ["types"],
      "properties": {
        "types": { "type": "array", "items": { "$ref": "#/$defs/sampleType" } },
        "anchors": {
          "type": "object",
          "description": "Per-type opaque anchor blob (base64); missing key = full sync for that type.",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "syncResultPage": {
      "type": "object",
      "required": ["type", "page_index", "more"],
      "properties": {
        "type": { "$ref": "#/$defs/sampleType" },
        "page_index": { "type": "integer", "minimum": 0 },
        "added":   { "type": "array", "items": { "$ref": "#/$defs/sample" } },
        "deleted": { "type": "array", "items": { "type": "string" } },
        "next_anchor": { "type": "string" },
        "more": { "type": "boolean" }
      }
    },

    "job": {
      "type": "object",
      "required": ["id", "kind", "created_at", "payload"],
      "properties": {
        "id":         { "$ref": "#/$defs/ulid" },
        "kind":       { "type": "string", "enum": ["read", "write", "sync"] },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "deadline":   { "$ref": "#/$defs/timestamp" },
        "payload":    { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "required": ["job_id", "page_index", "status"],
      "properties": {
        "job_id":     { "$ref": "#/$defs/ulid" },
        "page_index": { "type": "integer", "minimum": 0 },
        "status":     { "type": "string", "enum": ["done", "failed"] },
        "result":     { "type": "object" },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}
